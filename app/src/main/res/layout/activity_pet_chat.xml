<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F0FFF4"
    tools:context=".PetChatActivity">

    <!-- TOP BAR -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:background="#C8E6C9"
        android:elevation="6dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="16dp">

        <!-- Back Button: android:tint yerine app:tint kullan -->
        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/rounded_button_bg"
            android:contentDescription="@string/back"
            android:src="@drawable/ic_arrow_back"
            app:tint="#2E7D32" />

        <!-- Dino Avatar -->
        <ImageView
            android:id="@+id/ivBotAvatar"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="10dp"
            android:background="@drawable/circle_avatar_bg"
            android:contentDescription="@string/bot_avatar"
            android:padding="4dp"
            android:src="@drawable/pet_green" />

        <!-- Bot Name + Status -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/dinobot_name"
                android:textColor="#1B5E20"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvBotStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/dinobot_status"
                android:textColor="#2E7D32"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Info Button -->
        <ImageButton
            android:id="@+id/btnInfo"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/rounded_button_bg"
            android:contentDescription="@string/info"
            android:src="@drawable/ic_info_outline"
            app:tint="#2E7D32" />
    </LinearLayout>

    <!-- MESSAGES RECYCLERVIEW -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMessages"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:isScrollContainer="true"
        android:clipToPadding="false"
        android:paddingTop="12dp"
        android:paddingBottom="8dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:scrollbars="none"
        android:contentDescription="@string/messages_list"
        tools:listitem="@layout/item_message" />

    <!-- TYPING INDICATOR -->
    <LinearLayout
        android:id="@+id/typingIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginBottom="4dp"
        android:background="@drawable/bubble_bot_bg"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:visibility="gone">

        <View
            android:id="@+id/dot1"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_marginEnd="4dp"
            android:background="@drawable/typing_dot_bg" />

        <View
            android:id="@+id/dot2"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_marginEnd="4dp"
            android:background="@drawable/typing_dot_bg" />

        <View
            android:id="@+id/dot3"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/typing_dot_bg" />
    </LinearLayout>

    <!-- INPUT CONTAINER -->
    <LinearLayout
        android:id="@+id/inputContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#C8E6C9"
        android:elevation="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp">

        <!-- Quick Reply Button -->
        <ImageButton
            android:id="@+id/btnQuickReply"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/rounded_button_bg"
            android:contentDescription="@string/quick_reply"
            android:src="@drawable/ic_pets"
            app:tint="#2E7D32" />

        <!-- Text Input -->
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etMessage"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:background="@drawable/input_field_bg"
            android:hint="@string/dinobot_hint"
            android:maxLines="4"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:textColor="#1B5E20"
            android:textColorHint="#4CAF50"
            android:textSize="15sp" />

        <!-- Send Button -->
        <ImageButton
            android:id="@+id/btnSend"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/send_button_bg"
            android:contentDescription="@string/send"
            android:src="@drawable/ic_send"
            app:tint="#FFFFFF" />
    </LinearLayout>

</LinearLayout>